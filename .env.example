APP_ENV=development
ENV_FILE=.env
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://okk_mcp:change-me@postgres:5432/okk_mcp
REDIS_URL=redis://redis:6379/0
OKK_API_BASE_URL=http://host.docker.internal:8002/api/v1
MCP_OAUTH_SECRET=replace-with-at-least-32-random-characters
MCP_SESSION_ENCRYPTION_SECRET=replace-with-another-32-character-secret
MCP_ISSUER_URL=http://localhost:8020
MCP_RESOURCE_URL=http://localhost:8020/mcp
MCP_ACCESS_TOKEN_MINUTES=60
MCP_REFRESH_TOKEN_DAYS=30
MCP_LOGIN_ATTEMPTS_PER_MINUTE=8
MCP_CLEANUP_INTERVAL_MINUTES=60
MCP_AUDIT_RETENTION_DAYS=30
ANALYTICS_PARALLEL_REQUESTS=12
ANALYTICS_MAX_CALLS=5000
ANALYTICS_MAX_EMPLOYEES=2000
FORWARDED_ALLOW_IPS=127.0.0.1
