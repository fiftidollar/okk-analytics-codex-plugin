APP_ENV=production
ENV_FILE=.env.production
POSTGRES_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
DATABASE_URL=postgresql+asyncpg://okk_mcp:REPLACE_WITH_DATABASE_PASSWORD@postgres:5432/okk_mcp
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0
OKK_API_BASE_URL=https://okk-backend.akfixdev.ru/api/v1
MCP_OAUTH_SECRET=REPLACE_WITH_UNIQUE_RANDOM_OAUTH_SECRET_32_CHARS_MINIMUM
MCP_SESSION_ENCRYPTION_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_SESSION_SECRET_32_CHARS
MCP_ISSUER_URL=https://okk-mcp.akfixdev.ru
MCP_RESOURCE_URL=https://okk-mcp.akfixdev.ru/mcp
MCP_ACCESS_TOKEN_MINUTES=60
MCP_REFRESH_TOKEN_DAYS=30
MCP_LOGIN_ATTEMPTS_PER_MINUTE=8
MCP_CLEANUP_INTERVAL_MINUTES=60
MCP_AUDIT_RETENTION_DAYS=30
ANALYTICS_PARALLEL_REQUESTS=12
ANALYTICS_MAX_CALLS=5000
TRANSCRIPT_SEARCH_MAX_CALLS=1000
ANALYTICS_MAX_EMPLOYEES=2000
ANALYTICS_TRACE_ENABLED=true
FORWARDED_ALLOW_IPS=REPLACE_WITH_TRUSTED_INGRESS_PROXY_IPS
